# Copy this file to .env for standalone UI development (without Aspire).
# When running via Aspire (dotnet run --project src/Barkfest.AppHost),
# these values are injected automatically — no .env file needed.

# Base URL of the Barkfest API
VITE_API_BASE_URL=https://localhost:7001

# Base URL of Azure Blob Storage (Azurite default for local development)
VITE_BLOB_BASE_URL=http://127.0.0.1:10000/devstoreaccount1
